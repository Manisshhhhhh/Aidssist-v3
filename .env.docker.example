# Docker Compose local deployment example.

VITE_API_BASE_URL=http://127.0.0.1:8000
# Optional internal/demo API key. Browser-exposed keys are not real authentication.
# VITE_AIDSSIST_API_KEY=change-me-for-internal-demo-only

AIDSSIST_ENVIRONMENT=production
AIDSSIST_DATABASE_URL=sqlite:////data/aidssist.db
AIDSSIST_STORAGE_BACKEND=local
AIDSSIST_STORAGE_LOCAL_ROOT=/data/datasets
AIDSSIST_REPORTS_LOCAL_ROOT=/data/reports
AIDSSIST_DATASETS_DIR=/data/datasets
AIDSSIST_REPORTS_DIR=/data/reports
AIDSSIST_MAX_UPLOAD_MB=10
AIDSSIST_AUTH_ENABLED=false
# AIDSSIST_API_KEY=change-me-for-internal-demo-only
AIDSSIST_USER_AUTH_ENABLED=false
# Required when AIDSSIST_USER_AUTH_ENABLED=true.
# AIDSSIST_JWT_SECRET_KEY=replace-with-a-long-random-secret
AIDSSIST_JWT_ALGORITHM=HS256
AIDSSIST_ACCESS_TOKEN_EXPIRE_MINUTES=1440
AIDSSIST_RATE_LIMIT_ENABLED=true
AIDSSIST_RATE_LIMIT_REQUESTS=120
AIDSSIST_RATE_LIMIT_WINDOW_SECONDS=60
AIDSSIST_ASYNC_JOBS_ENABLED=false
AIDSSIST_JOB_POLL_INTERVAL_SECONDS=2
AIDSSIST_JOB_MAX_ATTEMPTS=3
AIDSSIST_JOB_STALE_AFTER_MINUTES=30
AIDSSIST_LOG_LEVEL=INFO
AIDSSIST_LOG_FORMAT=json
AIDSSIST_AUDIT_LOG_ENABLED=true
AIDSSIST_REQUEST_LOGGING_ENABLED=true
AIDSSIST_ERROR_DETAILS_ENABLED=false
AIDSSIST_LLM_ENABLED=false
AIDSSIST_LLM_PROVIDER=gemini
# Use a newly rotated Gemini key only. Previously pasted keys should be treated as compromised.
GEMINI_API_KEY=
AIDSSIST_GEMINI_MODEL=gemini-2.5-flash
AIDSSIST_LLM_TIMEOUT_SECONDS=30
AIDSSIST_LLM_MAX_INPUT_CHARS=30000
AIDSSIST_LLM_MAX_OUTPUT_TOKENS=1200
AIDSSIST_LLM_TEMPERATURE=0.2
AIDSSIST_SAFE_MODE=false
AIDSSIST_READ_ONLY_MODE=false
AIDSSIST_BACKUP_DIR=/data/backups
AIDSSIST_BACKUP_RETENTION_DAYS=14
AIDSSIST_STARTUP_PREFLIGHT_ENABLED=true
AIDSSIST_FAIL_FAST_ON_PREFLIGHT_ERROR=false
AIDSSIST_AUTO_BACKUP_BEFORE_MIGRATION=true
AIDSSIST_MAX_BACKUP_COUNT=20
AIDSSIST_CORS_ORIGINS=["http://127.0.0.1:8080","http://localhost:8080"]
AIDSSIST_CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|\[::1\])(:\d+)?$

# Future S3-compatible storage scaffold. S3 is not required for local Docker.
# AIDSSIST_S3_BUCKET=aidssist-bucket
# AIDSSIST_S3_REGION=us-east-1
# AIDSSIST_S3_ENDPOINT_URL=https://s3.amazonaws.com
# AIDSSIST_S3_ACCESS_KEY_ID=change-me
# AIDSSIST_S3_SECRET_ACCESS_KEY=change-me
# AIDSSIST_S3_PREFIX=aidssist
